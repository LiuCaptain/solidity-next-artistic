    "sources": {
      "project/contracts/Counter.sol": {
        "content": "// SPDX-License-Identifier: UNLICENSED\npragma solidity ^0.8.28;\n\ncontract Counter {\n\tuint public x;\n\n\tevent Increment(uint by);\n\n\tfunction inc() public {\n\t\tx++;\n\t\temit Increment(1);\n\t}\n\n\tfunction incBy(uint by) public {\n\t\trequire(by > 0, \"incBy: increment should be positive\");\n\t\tx += by;\n\t\temit Increment(by);\n\t}\n}\n"
      }
    }
